# Managed by Ansible (deployment/ansible/playbook.yml) — do not edit by hand.
# Secret values (secrets.*) come from the ansible-vault file delivered via
# cloud-init; non-secret values come from Terraform (-e @vars.json) / group_vars.
# Consumed by docker compose --env-file.

# --- images ---
DOCKER_IMAGE_BACKEND={{ docker_image_backend }}
DOCKER_IMAGE_FRONTEND={{ docker_image_frontend }}

# --- database ---
POSTGRES_DB={{ POSTGRES_DB }}
POSTGRES_USER={{ POSTGRES_USER }}
POSTGRES_PASSWORD={{ secrets.POSTGRES_PASSWORD }}
DATABASE_URL={{ secrets.DATABASE_URL }}

# --- auth ---
JWT_SECRET={{ secrets.JWT_SECRET }}
JWT_ALG={{ JWT_ALG }}
JWT_EXPIRE_MIN={{ JWT_EXPIRE_MIN }}
COOKIE_SECURE={{ COOKIE_SECURE }}
COOKIE_SAMESITE={{ COOKIE_SAMESITE }}
COOKIE_DOMAIN={{ COOKIE_DOMAIN }}
CORS_ALLOW_ORIGINS={{ CORS_ALLOW_ORIGINS }}
MASTER_CONSENT_VERSION={{ MASTER_CONSENT_VERSION }}

# --- app ---
APP_TIMEZONE={{ APP_TIMEZONE }}
FRONTEND_BASE_URL={{ FRONTEND_BASE_URL }}
DOCTOR_INVITE_TTL_HOURS={{ DOCTOR_INVITE_TTL_HOURS }}

# --- livekit ---
LIVEKIT_URL={{ LIVEKIT_URL }}
LIVEKIT_API_KEY={{ secrets.LIVEKIT_API_KEY }}
LIVEKIT_API_SECRET={{ secrets.LIVEKIT_API_SECRET }}

# --- object storage (S3 / Cloudflare R2) ---
S3_ENDPOINT_URL={{ secrets.S3_ENDPOINT_URL }}
S3_REGION={{ S3_REGION }}
S3_BUCKET={{ secrets.S3_BUCKET }}
S3_ACCESS_KEY_ID={{ secrets.S3_ACCESS_KEY_ID }}
S3_SECRET_ACCESS_KEY={{ secrets.S3_SECRET_ACCESS_KEY }}
S3_FORCE_PATH_STYLE={{ S3_FORCE_PATH_STYLE }}

# --- email (Resend) ---
RESEND_API_KEY={{ secrets.RESEND_API_KEY }}
RESEND_FROM={{ RESEND_FROM }}
RESEND_REPLY_TO={{ RESEND_REPLY_TO }}
RESEND_WEBHOOK_SECRET={{ secrets.RESEND_WEBHOOK_SECRET }}

# --- frontend (build-time inlined; passed for completeness) ---
NEXT_PUBLIC_API_URL={{ NEXT_PUBLIC_API_URL }}
NEXT_PUBLIC_APP_TIMEZONE={{ NEXT_PUBLIC_APP_TIMEZONE }}
