# Terraform local working cache — provider plugins downloaded by `terraform
# init`. Large, platform-specific binaries; regenerated by CI (deploy.yml) and
# locally on every init. The pinned versions/hashes live in the committed
# .terraform.lock.hcl, so this directory carries nothing worth tracking.
.terraform/

# State is stored in the remote http backend (terraform.tf), never on disk.
# Ignore any local state that shows up so it can't be committed by accident.
*.tfstate
*.tfstate.*
.terraform.tfstate.lock.info

# Saved plan files and crash logs.
*.tfplan
crash.log
crash.*.log

# Ephemeral files the Deployment workflow writes into this directory at runtime
# (SSH key, vault password, generated inventory and extra-vars). They contain
# secrets/credentials and must never be committed.
ssh_key
ssh_key.pub
vaultpass
inventory.ini
vars.json

# NOTE: terraform.tfvars IS committed on purpose (image-tag pin, no secrets —
# secrets flow through SOPS/ansible-vault). Do not add *.tfvars here.
