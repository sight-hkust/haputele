# Copy to .env (docker-compose reads .env automatically). Override anything you need.
#
# Alternative: the api also reads an optional YAML config file. See
# config.yaml.example for the schema. Precedence (highest → lowest) is:
# real env vars > .env > config.yaml > code defaults. Override the YAML
# path with CONFIG_FILE=/path/to/your.yaml; default is ./config.yaml.

# Postgres
POSTGRES_DB=haputele
POSTGRES_USER=hapu
POSTGRES_PASSWORD=hapu
POSTGRES_PORT=5432

# API
API_PORT=8000
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALG=HS256
JWT_EXPIRE_MIN=480

# Session cookie controls. The JWT is delivered to the browser as an
# HttpOnly cookie; a non-HttpOnly companion (`csrf_token`) is echoed by
# the client as `X-CSRF-Token` on unsafe verbs. Set COOKIE_SECURE=false
# ONLY for local HTTP dev — anything user-facing must stay true so the
# cookies aren't sent in cleartext. SameSite=lax blocks the common CSRF
# vectors while letting top-level navigations carry the session.
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# Comma-separated origins allowed to make credentialed requests. Leave
# empty when frontend and API share an origin (the default with
# next.config.mjs's /api rewrite). Wildcard "*" is rejected by browsers
# in credentialed mode — list every origin explicitly when crossing.
CORS_ALLOW_ORIGINS=

# First-run wizard prefill defaults. The setup wizard prefills its form
# from these values; once /setup/initialize succeeds, runtime reads
# everything from the system_config DB row and these env vars are ignored.
MASTER_CONSENT_VERSION=v1

# Frontend
FRONTEND_PORT=3000
# Inlined into the client bundle at build time; must be reachable from the
# user's browser (not from inside the compose network).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Application timezone — applied to PDF date stamps, export filenames, and
# the calendar/formatters in the client. Default is Sri Lanka.
APP_TIMEZONE=Asia/Colombo

# Object storage (S3-compatible). In dev the `rustfs` compose service
# provides a local S3 endpoint at http://rustfs:9000 (console on :9001);
# the `s3-init` one-shot creates the bucket on `docker compose up`. In
# prod, set S3_ENDPOINT_URL to your real S3 (leave blank for AWS S3) and
# flip S3_FORCE_PATH_STYLE to false unless the endpoint requires it.
S3_ENDPOINT_URL=http://rustfs:9000
S3_REGION=us-east-1
S3_BUCKET=haputele
S3_ACCESS_KEY_ID=rustfsadmin
S3_SECRET_ACCESS_KEY=rustfsadmin
S3_FORCE_PATH_STYLE=true
S3_PORT=9000
S3_CONSOLE_PORT=9001

# LiveKit (video transport). The api signs join tokens locally with
# LIVEKIT_API_SECRET and verifies webhook callbacks with the same key. The
# browser receives `serverUrl` in the API response and connects directly to
# LIVEKIT_URL — the api never opens a network connection to LiveKit itself.
# Rotate to long random strings (secret ≥ 32 chars) before any real deploy.
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret-must-be-at-least-32-chars-long
# IP advertised to browsers as the WebRTC ICE candidate. The container's
# Docker bridge IP (172.x.x.x) is unreachable from the browser, so we pin
# this to whatever host browsers actually connect to: 127.0.0.1 for a
# same-machine test, or your LAN IP if testing from a second device.
LIVEKIT_NODE_IP=127.0.0.1
